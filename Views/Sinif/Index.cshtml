@model List<Sinif>

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0"><i class="bi bi-door-open me-2"></i>Sınıf Yönetimi</h5>
            <a asp-action="Ekle" class="btn btn-success btn-sm shadow-sm">
                <i class="bi bi-plus-lg"></i> Yeni Sınıf Ekle
            </a>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Sınıf Adı</th>
                        <th class="text-center" style="width: 200px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4 fw-bold">@item.Ad</td>
                            <td class="text-center">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="Guncelle" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">Düzenle</a>
                                    <a asp-action="Sil" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" 
                                       onclick="return confirm('@item.Ad sınıfını silmek istediğinize emin misiniz?')">Sil</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>