@model List<Ogrenci>

@{
    ViewData["Title"] = "Öğrenci Listesi";
}

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0"><i class="bi bi-people-fill me-2"></i>Öğrenci Yönetimi</h5>
            <a asp-action="Ekle" class="btn btn-success btn-sm shadow-sm">
                <i class="bi bi-person-plus-fill"></i> Yeni Öğrenci Ekle
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">No</th>
                            <th>Ad Soyad</th>
                            <th>Sınıfı</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="badge bg-secondary">#@item.OkulNo</span>
                                    </td>
                                    <td>
                                        <div class="fw-bold">@item.Ad @item.Soyad</div>
                                    </td>
                                    <td>
                                        @if (item.Sinif != null)
                                        {
                                            <span class="badge bg-info text-dark">
                                                <i class="bi bi-door-open me-1"></i>@item.Sinif.Ad
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small italic">Sınıf atanmadı</span>
                                        }
                                    </td>
                                    <td class="text-center">
    <div class="btn-group shadow-sm">
        <a asp-action="Guncelle" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">
            <i class="bi bi-pencil-fill"></i> Düzenle
        </a>
        
        <a asp-action="Sil" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" 
           onclick="return confirm('@item.Ad @item.Soyad isimli öğrenciyi silmek istediğine emin misin?')">
            <i class="bi bi-trash-fill"></i> Sil
        </a>
    </div>
</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-emoji-frown d-block mb-2" style="font-size: 2rem;"></i>
                                    Henüz hiç öğrenci eklenmemiş.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>