@model IEnumerable<EnSonProje.Models.Kitap>

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0"><i class="bi bi-book"></i> Kitap Envanteri</h3>
            <a asp-action="Ekle" class="btn btn-light btn-sm fw-bold shadow-sm">
                <i class="bi bi-plus-lg"></i> Yeni Kitap Ekle
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 25%">Kitap Adı</th>
                            <th style="width: 20%">Yazar</th>
                            <th style="width: 20%">Yayınevi</th>
                            <th style="width: 15%">Kategori</th>
                            <th style="width: 20%" class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.Ad</td>
                                <td>@item.Yazar</td>
                                <td>@item.YayınEvi</td>
                                <td>
                                    <span class="badge bg-info text-dark">@(item.Kategori?.Ad ?? "Belirtilmemiş")</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm" role="group">
                                        <a asp-action="Guncelle" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">
                                            Düzenle
                                        </a>
                                        <a asp-action="Sil" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" 
                                           onclick="return confirm('Bu kitabı silmek istediğinize emin misiniz?')">
                                            Sil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>