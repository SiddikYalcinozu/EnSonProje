<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Kütüphane Yönetim Sistemi</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            overflow-x:hidden;
        }

        .sidebar{
            height:100vh;
            width:240px;
            position:fixed;
            background:#1e293b;
            color:white;
        }

        .sidebar a{
            color:white;
            text-decoration:none;
            display:block;
            padding:12px 20px;
        }

        .sidebar a:hover{
            background:#334155;
        }

        .main-content{
            margin-left:240px;
            padding:20px;
        }

        .sidebar-title{
            font-size:22px;
            padding:20px;
            border-bottom:1px solid #334155;
        }
    </style>

</head>

<body>

<div class="sidebar">

<div class="sidebar-title">
📚 Kütüphane
</div>

<a asp-controller="Home" asp-action="Index">
🏠 Anasayfa
</a>

<a asp-controller="Kitap" asp-action="Index">
📖 Kitaplar
</a>





<a asp-controller="Kitap" asp-action="Ekle">
➕ Kitap Ekle
</a>

<a asp-controller="Kategori" asp-action="Index">
➕ Kategori Ekle
</a>


</div>


<div class="main-content">

<nav class="navbar navbar-light bg-light mb-4 rounded shadow-sm">
<div class="container-fluid">

<span class="navbar-brand mb-0 h5">
Kütüphane Yönetim Paneli
</span>

</div>
</nav>

<div class="container-fluid">

@RenderBody()

</div>

</div>

@RenderSection("Scripts", required: false)

</body>
</html>
