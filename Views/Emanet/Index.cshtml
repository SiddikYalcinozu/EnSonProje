@model IEnumerable<EnSonProje.Models.Emanet>

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0"><i class="bi bi-arrow-left-right me-2"></i>Emanet Hareketleri</h5>
            <a asp-action="Ver" class="btn btn-primary btn-sm shadow-sm">
                <i class="bi bi-plus-circle"></i> Yeni Kitap Ver
            </a>
        </div>
        <div class="card-body p-0 text-start">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Öğrenci</th>
                        <th>Kitap</th>
                        <th>Veriliş Tarihi</th>
                        <th>Durum / Teslim Tarihi</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4 fw-bold">@item.Ogrenci?.Ad @item.Ogrenci?.Soyad</td>
                            <td>@item.Kitap?.Ad</td>
                            <td>@item.VerilisTarihi.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (item.TeslimTarihi == null) {
                                    <span class="badge bg-warning text-dark">Öğrencide</span>
                                } else {
                                    <span class="badge bg-success">Teslim Edildi (@item.TeslimTarihi?.ToString("dd.MM.yyyy"))</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.TeslimTarihi == null) {
                                    <a asp-action="TeslimAl" asp-route-id="@item.Id" class="btn btn-outline-success btn-sm">
                                        <i class="bi bi-check2-square"></i> Teslim Al
                                    </a>
                                } else {
                                    <button class="btn btn-light btn-sm text-muted" disabled>Tamamlandı</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>